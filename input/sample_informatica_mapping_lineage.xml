  <CONNECTOR FROMINSTANCE="exp_CalcAmountAndCategory" FROMFIELD="IS_FRAUD_FLAGGED" TOINSTANCE="upd_MarkInsert" TOFIELD="IS_FRAUD_FLAGGED"/>
