  <CONNECTOR FROMINSTANCE="jnr_Txn_ExchangeRates" FROMFIELD="TRANSACTION_ID"   TOINSTANCE="exp_CalcAmountAndCategory" TOFIELD="TRANSACTION_ID"/>
