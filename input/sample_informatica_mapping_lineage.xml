<!-- ==========================================================================
     MAPPING 1: m_Load_Dim_Branch
     Lineage complexity: LOW - straight passthrough, one source, one target
     ========================================================================== -->

<MAPPING NAME="m_Load_Dim_Branch" DESCRIPTION="Full refresh load of DIM_BRANCH from source BRANCHES">

  <TRANSFORMATION NAME="SQ_Branches" TYPE="Source Qualifier" DESCRIPTION="Source Qualifier for BRANCHES">
    <TRANSFORMFIELD NAME="BRANCH_ID"    PORTTYPE="OUTPUT" DATATYPE="decimal" PRECISION="6"/>
    <TRANSFORMFIELD NAME="BRANCH_NAME"  PORTTYPE="OUTPUT" DATATYPE="varchar" PRECISION="100"/>
    <TRANSFORMFIELD NAME="REGION"       PORTTYPE="OUTPUT" DATATYPE="varchar" PRECISION="50"/>
    <TRANSFORMFIELD NAME="STATE_CODE"   PORTTYPE="OUTPUT" DATATYPE="varchar" PRECISION="2"/>
    <TRANSFORMFIELD NAME="BRANCH_TYPE"  PORTTYPE="OUTPUT" DATATYPE="varchar" PRECISION="20"/>
  </TRANSFORMATION>

  <INSTANCE NAME="BRANCHES"     TRANSFORMATION_TYPE="Source Definition" TYPE="SOURCE"/>
  <INSTANCE NAME="SQ_Branches"  TRANSFORMATION_TYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="DIM_BRANCH"   TRANSFORMATION_TYPE="Target Definition" TYPE="TARGET"/>

  <CONNECTOR FROMINSTANCE="BRANCHES" FROMFIELD="BRANCH_ID"    TOINSTANCE="SQ_Branches" TOFIELD="BRANCH_ID"/>
  <CONNECTOR FROMINSTANCE="BRANCHES" FROMFIELD="BRANCH_NAME"  TOINSTANCE="SQ_Branches" TOFIELD="BRANCH_NAME"/>
  <CONNECTOR FROMINSTANCE="BRANCHES" FROMFIELD="REGION"       TOINSTANCE="SQ_Branches" TOFIELD="REGION"/>
  <CONNECTOR FROMINSTANCE="BRANCHES" FROMFIELD="STATE_CODE"   TOINSTANCE="SQ_Branches" TOFIELD="STATE_CODE"/>
  <CONNECTOR FROMINSTANCE="BRANCHES" FROMFIELD="BRANCH_TYPE"  TOINSTANCE="SQ_Branches" TOFIELD="BRANCH_TYPE"/>

  <CONNECTOR FROMINSTANCE="SQ_Branches" FROMFIELD="BRANCH_ID"    TOINSTANCE="DIM_BRANCH" TOFIELD="BRANCH_ID"/>
  <CONNECTOR FROMINSTANCE="SQ_Branches" FROMFIELD="BRANCH_NAME"  TOINSTANCE="DIM_BRANCH" TOFIELD="BRANCH_NAME"/>
  <CONNECTOR FROMINSTANCE="SQ_Branches" FROMFIELD="REGION"       TOINSTANCE="DIM_BRANCH" TOFIELD="REGION"/>
  <CONNECTOR FROMINSTANCE="SQ_Branches" FROMFIELD="STATE_CODE"   TOINSTANCE="DIM_BRANCH" TOFIELD="STATE_CODE"/>
  <CONNECTOR FROMINSTANCE="SQ_Branches" FROMFIELD="BRANCH_TYPE"  TOINSTANCE="DIM_BRANCH" TOFIELD="BRANCH_TYPE"/>

</MAPPING>


<!-- ==========================================================================
     MAPPING 2: m_Load_Fact_Transactions
     Lineage complexity: VERY HIGH
       - 3 source pipelines joined (Transactions, Accounts, Exchange Rates)
       - 2 lookups against dimension tables (Dim_Customer, Dim_Branch)
       - Expression transformation with derived/calculated ports
         (currency conversion, CASE/IIF categorization logic)
       - Filter transformation (excludes reversed transactions)
       - Update Strategy transformation (marks rows for insert)
     ========================================================================== -->

<MAPPING NAME="m_Load_Fact_Transactions" DESCRIPTION="Daily incremental load of FACT_TRANSACTIONS with currency conversion, categorization, and fraud flagging">

  <!-- Source Qualifiers -->
  <TRANSFORMATION NAME="SQ_Transactions" TYPE="Source Qualifier">
    <TRANSFORMFIELD NAME="TRANSACTION_ID"   PORTTYPE="OUTPUT" DATATYPE="decimal"  PRECISION="15"/>
    <TRANSFORMFIELD NAME="ACCOUNT_ID"       PORTTYPE="OUTPUT" DATATYPE="decimal"  PRECISION="12"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TS"   PORTTYPE="OUTPUT" DATATYPE="timestamp" PRECISION="29"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TYPE" PORTTYPE="OUTPUT" DATATYPE="varchar"  PRECISION="20"/>
    <TRANSFORMFIELD NAME="AMOUNT"           PORTTYPE="OUTPUT" DATATYPE="decimal"  PRECISION="15" SCALE="2"/>
    <TRANSFORMFIELD NAME="CURRENCY_CODE"    PORTTYPE="OUTPUT" DATATYPE="varchar"  PRECISION="3"/>
    <TRANSFORMFIELD NAME="CHANNEL"          PORTTYPE="OUTPUT" DATATYPE="varchar"  PRECISION="20"/>
    <TRANSFORMFIELD NAME="IS_REVERSED"      PORTTYPE="OUTPUT" DATATYPE="boolean"  PRECISION="1"/>
  </TRANSFORMATION>

  <TRANSFORMATION NAME="SQ_Accounts" TYPE="Source Qualifier">
    <TRANSFORMFIELD NAME="ACCOUNT_ID"   PORTTYPE="OUTPUT" DATATYPE="decimal" PRECISION="12"/>
    <TRANSFORMFIELD NAME="CUSTOMER_ID"  PORTTYPE="OUTPUT" DATATYPE="decimal" PRECISION="10"/>
    <TRANSFORMFIELD NAME="BRANCH_ID"    PORTTYPE="OUTPUT" DATATYPE="decimal" PRECISION="6"/>
  </TRANSFORMATION>

  <TRANSFORMATION NAME="SQ_ExchangeRates" TYPE="Source Qualifier">
    <TRANSFORMFIELD NAME="CURRENCY_CODE" PORTTYPE="OUTPUT" DATATYPE="varchar" PRECISION="3"/>
    <TRANSFORMFIELD NAME="RATE_DATE"     PORTTYPE="OUTPUT" DATATYPE="date"    PRECISION="10"/>
    <TRANSFORMFIELD NAME="RATE_TO_USD"   PORTTYPE="OUTPUT" DATATYPE="decimal" PRECISION="10" SCALE="6"/>
  </TRANSFORMATION>

  <!-- Filter: drop reversed transactions before any joins -->
  <TRANSFORMATION NAME="fil_ExcludeReversed" TYPE="Filter">
    <TRANSFORMFIELD NAME="TRANSACTION_ID"   PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="ACCOUNT_ID"       PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TS"   PORTTYPE="INPUT/OUTPUT" DATATYPE="timestamp"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TYPE" PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="AMOUNT"           PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CURRENCY_CODE"    PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="CHANNEL"          PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TABLEATTRIBUTE NAME="Filter Condition" VALUE="IS_REVERSED = FALSE"/>
  </TRANSFORMATION>

  <!-- Joiner: Transactions (Master) to Accounts (Detail) on ACCOUNT_ID -->
  <TRANSFORMATION NAME="jnr_Txn_Accounts" TYPE="Joiner">
    <TRANSFORMFIELD NAME="TRANSACTION_ID"   PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="ACCOUNT_ID_TXN"   PORTTYPE="INPUT"        DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TS"   PORTTYPE="INPUT/OUTPUT" DATATYPE="timestamp"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TYPE" PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="AMOUNT"           PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CURRENCY_CODE"    PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="CHANNEL"          PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="ACCOUNT_ID_ACC"   PORTTYPE="INPUT"        DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CUSTOMER_ID"      PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="BRANCH_ID"        PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TABLEATTRIBUTE NAME="Join Condition" VALUE="ACCOUNT_ID_TXN = ACCOUNT_ID_ACC"/>
    <TABLEATTRIBUTE NAME="Join Type" VALUE="Normal Join"/>
  </TRANSFORMATION>

  <!-- Joiner: prior result to Exchange Rates on CURRENCY_CODE + RATE_DATE -->
  <TRANSFORMATION NAME="jnr_Txn_ExchangeRates" TYPE="Joiner">
    <TRANSFORMFIELD NAME="TRANSACTION_ID"    PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TS"    PORTTYPE="INPUT/OUTPUT" DATATYPE="timestamp"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TYPE"  PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="AMOUNT"            PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CURRENCY_CODE"     PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="CHANNEL"           PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="CUSTOMER_ID"       PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="BRANCH_ID"         PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="RATE_TO_USD"       PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TABLEATTRIBUTE NAME="Join Condition" VALUE="CURRENCY_CODE = CURRENCY_CODE AND CAST(TRANSACTION_TS AS DATE) = RATE_DATE"/>
    <TABLEATTRIBUTE NAME="Join Type" VALUE="Master Outer Join"/>
  </TRANSFORMATION>

  <!-- Lookup: Dim_Customer, unconnected-style lookup on CUSTOMER_ID -->
  <TRANSFORMATION NAME="lkp_DimCustomer" TYPE="Lookup Procedure">
    <TRANSFORMFIELD NAME="CUSTOMER_ID_IN" PORTTYPE="INPUT"  DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CUSTOMER_KEY"   PORTTYPE="OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="IS_CURRENT"     PORTTYPE="OUTPUT" DATATYPE="boolean"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="CUSTOMER_ID = CUSTOMER_ID_IN AND IS_CURRENT = TRUE"/>
    <TABLEATTRIBUTE NAME="Lookup source"    VALUE="DIM_CUSTOMER"/>
  </TRANSFORMATION>

  <!-- Lookup: Dim_Branch on BRANCH_ID -->
  <TRANSFORMATION NAME="lkp_DimBranch" TYPE="Lookup Procedure">
    <TRANSFORMFIELD NAME="BRANCH_ID_IN" PORTTYPE="INPUT"  DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="BRANCH_KEY"   PORTTYPE="OUTPUT" DATATYPE="decimal"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="BRANCH_ID = BRANCH_ID_IN"/>
    <TABLEATTRIBUTE NAME="Lookup source"    VALUE="DIM_BRANCH_LKP"/>
  </TRANSFORMATION>

  <!-- Lookup: Fraud flag existence check -->
  <TRANSFORMATION NAME="lkp_FraudFlags" TYPE="Lookup Procedure">
    <TRANSFORMFIELD NAME="TRANSACTION_ID_IN"  PORTTYPE="INPUT"  DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="FRAUD_TRANSACTION_ID" PORTTYPE="OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="SEVERITY"           PORTTYPE="OUTPUT" DATATYPE="varchar"/>
    <TABLEATTRIBUTE NAME="Lookup condition" VALUE="TRANSACTION_ID = TRANSACTION_ID_IN"/>
    <TABLEATTRIBUTE NAME="Lookup source"    VALUE="FRAUD_FLAGS"/>
  </TRANSFORMATION>

  <!-- Expression: currency conversion + categorization + fraud boolean -->
  <TRANSFORMATION NAME="exp_CalcAmountAndCategory" TYPE="Expression">
    <TRANSFORMFIELD NAME="TRANSACTION_ID"   PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TYPE" PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="CHANNEL"          PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="AMOUNT"           PORTTYPE="INPUT"        DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="RATE_TO_USD"      PORTTYPE="INPUT"        DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CUSTOMER_KEY"     PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="BRANCH_KEY"       PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="FRAUD_TRANSACTION_ID" PORTTYPE="INPUT"    DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="SEVERITY"         PORTTYPE="INPUT"        DATATYPE="varchar"/>
    <TRANSFORMFIELD
        NAME="AMOUNT_USD"
        PORTTYPE="OUTPUT"
        DATATYPE="decimal"
        PRECISION="15"
        SCALE="2"
        EXPRESSION="ROUND(AMOUNT * IIF(ISNULL(RATE_TO_USD), 1.0, RATE_TO_USD), 2)"/>
    <TRANSFORMFIELD
        NAME="TXN_CATEGORY"
        PORTTYPE="OUTPUT"
        DATATYPE="varchar"
        PRECISION="30"
        EXPRESSION="IIF(TRANSACTION_TYPE = 'FEE', 'FEE_INCOME',
                     IIF(TRANSACTION_TYPE = 'INTEREST', 'INTEREST_INCOME',
                     IIF(TRANSACTION_TYPE = 'DEPOSIT' AND AMOUNT_USD &gt;= 10000, 'LARGE_DEPOSIT',
                     IIF(TRANSACTION_TYPE = 'DEPOSIT', 'STANDARD_DEPOSIT',
                     IIF(TRANSACTION_TYPE = 'WITHDRAWAL' AND CHANNEL = 'ATM', 'ATM_WITHDRAWAL',
                     IIF(TRANSACTION_TYPE = 'WITHDRAWAL', 'STANDARD_WITHDRAWAL',
                     IIF(TRANSACTION_TYPE = 'TRANSFER', 'TRANSFER', 'OTHER')))))))"/>
    <TRANSFORMFIELD
        NAME="IS_FRAUD_FLAGGED"
        PORTTYPE="OUTPUT"
        DATATYPE="boolean"
        EXPRESSION="IIF(NOT ISNULL(FRAUD_TRANSACTION_ID) AND (SEVERITY = 'MEDIUM' OR SEVERITY = 'HIGH'), TRUE, FALSE)"/>
    <TRANSFORMFIELD
        NAME="LOAD_TS"
        PORTTYPE="OUTPUT"
        DATATYPE="timestamp"
        EXPRESSION="SYSTIMESTAMP"/>
  </TRANSFORMATION>

  <!-- Update Strategy: mark all rows for insert -->
  <TRANSFORMATION NAME="upd_MarkInsert" TYPE="Update Strategy">
    <TRANSFORMFIELD NAME="TRANSACTION_ID"   PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="CUSTOMER_KEY"     PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="BRANCH_KEY"       PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="TRANSACTION_TYPE" PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="TXN_CATEGORY"     PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="CHANNEL"          PORTTYPE="INPUT/OUTPUT" DATATYPE="varchar"/>
    <TRANSFORMFIELD NAME="AMOUNT_USD"       PORTTYPE="INPUT/OUTPUT" DATATYPE="decimal"/>
    <TRANSFORMFIELD NAME="IS_FRAUD_FLAGGED" PORTTYPE="INPUT/OUTPUT" DATATYPE="boolean"/>
    <TRANSFORMFIELD NAME="LOAD_TS"          PORTTYPE="INPUT/OUTPUT" DATATYPE="timestamp"/>
    <TABLEATTRIBUTE NAME="Update Strategy Expression" VALUE="DD_INSERT"/>
  </TRANSFORMATION>

  <!-- Instances -->
  <INSTANCE NAME="TRANSACTIONS"                TRANSFORMATION_TYPE="Source Definition" TYPE="SOURCE"/>
  <INSTANCE NAME="ACCOUNTS"                    TRANSFORMATION_TYPE="Source Definition" TYPE="SOURCE"/>
  <INSTANCE NAME="EXCHANGE_RATES"              TRANSFORMATION_TYPE="Source Definition" TYPE="SOURCE"/>
  <INSTANCE NAME="SQ_Transactions"             TRANSFORMATION_TYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="SQ_Accounts"                 TRANSFORMATION_TYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="SQ_ExchangeRates"            TRANSFORMATION_TYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="fil_ExcludeReversed"         TRANSFORMATION_TYPE="Filter"            TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="jnr_Txn_Accounts"            TRANSFORMATION_TYPE="Joiner"            TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="jnr_Txn_ExchangeRates"       TRANSFORMATION_TYPE="Joiner"            TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="lkp_DimCustomer"             TRANSFORMATION_TYPE="Lookup Procedure"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="lkp_DimBranch"               TRANSFORMATION_TYPE="Lookup Procedure"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="lkp_FraudFlags"              TRANSFORMATION_TYPE="Lookup Procedure"  TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="exp_CalcAmountAndCategory"   TRANSFORMATION_TYPE="Expression"        TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="upd_MarkInsert"              TRANSFORMATION_TYPE="Update Strategy"   TYPE="TRANSFORMATION"/>
  <INSTANCE NAME="FACT_TRANSACTIONS"           TRANSFORMATION_TYPE="Target Definition" TYPE="TARGET"/>

  <!-- Connectors: Source -> Source Qualifier -->
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="TRANSACTION_ID"   TOINSTANCE="SQ_Transactions" TOFIELD="TRANSACTION_ID"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="ACCOUNT_ID"       TOINSTANCE="SQ_Transactions" TOFIELD="ACCOUNT_ID"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="TRANSACTION_TS"   TOINSTANCE="SQ_Transactions" TOFIELD="TRANSACTION_TS"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="TRANSACTION_TYPE" TOINSTANCE="SQ_Transactions" TOFIELD="TRANSACTION_TYPE"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="AMOUNT"           TOINSTANCE="SQ_Transactions" TOFIELD="AMOUNT"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="CURRENCY_CODE"    TOINSTANCE="SQ_Transactions" TOFIELD="CURRENCY_CODE"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="CHANNEL"          TOINSTANCE="SQ_Transactions" TOFIELD="CHANNEL"/>
  <CONNECTOR FROMINSTANCE="TRANSACTIONS" FROMFIELD="IS_REVERSED"      TOINSTANCE="SQ_Transactions" TOFIELD="IS_REVERSED"/>

  <CONNECTOR FROMINSTANCE="ACCOUNTS" FROMFIELD="ACCOUNT_ID"  TOINSTANCE="SQ_Accounts" TOFIELD="ACCOUNT_ID"/>
  <CONNECTOR FROMINSTANCE="ACCOUNTS" FROMFIELD="CUSTOMER_ID" TOINSTANCE="SQ_Accounts" TOFIELD="CUSTOMER_ID"/>
  <CONNECTOR FROMINSTANCE="ACCOUNTS" FROMFIELD="BRANCH_ID"   TOINSTANCE="SQ_Accounts" TOFIELD="BRANCH_ID"/>

  <CONNECTOR FROMINSTANCE="EXCHANGE_RATES" FROMFIELD="CURRENCY_CODE" TOINSTANCE="SQ_ExchangeRates" TOFIELD="CURRENCY_CODE"/>
